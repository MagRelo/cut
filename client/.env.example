# ===========================================
# Client env (Vite) — bake-time only
# ===========================================
# Copied into the JS bundle at `pnpm client:build` / `pnpm run deploy`.
# NOT set in Swarm web.env / cron.env. Use client/.env.production for prod builds.
# Vite also injects DEV / PROD / MODE — do not use a custom VITE_NODE_ENV.

# --- Required for a working app ---

# Public API base (include /api). Default in code: http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api

# Privy Dashboard → App settings → App ID (must match server PRIVY_APP_ID)
VITE_PRIVY_APP_ID=

# Public address of OPS_ORACLE (server OPS_ORACLE_PK). Must match on-chain contest oracle.
VITE_ORACLE_ADDRESS=0xYourOpsOracleAddressHere

# Must match server REFERRAL_GROUP_ID (32-byte hex, 0x + 64 chars)
VITE_REFERRAL_GROUP_ID=0x...

# Side bet stakes (USDC transfer on place); separate from OPS_ORACLE
VITE_SIDE_BET_STAKE_RECIPIENT=0xYourSideBetTreasuryAddressHere

# --- Optional / defaults (commented) ---

# Chain for wallet auth: mainnet (Base) or testnet (Base Sepolia). Default: testnet
# VITE_TARGET_CHAIN=testnet

# Base Sepolia JSON-RPC (optional). CDP → Node → Base Sepolia, or any HTTPS endpoint.
# Unset → wagmi chain default RPC.
# VITE_BASE_SEPOLIA_RPC_URL=https://api.developer.coinbase.com/rpc/v1/...

# PostHog project key (client analytics; only used when Vite PROD). Unset = no PostHog.
# VITE_POSTHOG_KEY=

# Referral network fee BPS on contest create. Default: 500
# VITE_REFERRAL_NETWORK_BPS=500

# BPS of each primary deposit to per-entry secondary subsidy
# (ContestController primaryDepositSecondarySubsidyBps). Default: 0
# VITE_PRIMARY_DEPOSIT_SECONDARY_SUBSIDY_BPS=0

# Pimlico sponsorship policy for smart-wallet sponsored txs (Dashboard → id sp_…)
# Unset = no paymaster context.
# VITE_PIMLICO_SPONSORSHIP_POLICY_ID=
