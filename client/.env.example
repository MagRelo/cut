# Environment
VITE_NODE_ENV=development

# Chain for wallet auth: mainnet (Base) or testnet (Base Sepolia). Omit defaults to testnet.
VITE_TARGET_CHAIN=testnet

# Base Sepolia RPC (optional). Paste the full URL from CDP → Node → Base Sepolia, or any HTTPS JSON-RPC endpoint.
# VITE_BASE_SEPOLIA_RPC_URL=https://api.developer.coinbase.com/rpc/v1/...

# API Configuration
VITE_API_URL=http://localhost:3000/api

# posthog reporting
VITE_POSTHOG_KEY=key

# create contest constant
VITE_ORACLE_ADDRESS=0xYourOracleAddressHere

# privy setup (Dashboard → App settings → App ID)
VITE_PRIVY_APP_ID=

# Pimlico sponsorship policy for smart-wallet sponsored txs (Dashboard → Sponsorship policies → id `sp_…`)
# VITE_SPONSORSHIP_POLICY_ID is an alias.
# VITE_PIMLICO_SPONSORSHIP_POLICY_ID=