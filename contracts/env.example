# =============================================================================
# CONTRACTS / SCRIPTS ENVIRONMENT
# =============================================================================
# Copy to contracts/.env and fill in values.
#
# Consumers:
#   - foundry.toml ([rpc_endpoints], [etherscan])
#   - contracts/script/Deploy_sepolia.s.sol, Deploy_base.s.sol
#   - scripts/deploy.js, scripts/verify.js
#   - scripts/sepolia/*.js
#
# All scripts load contracts/.env via dotenv (from repo root).

# -----------------------------------------------------------------------------
# Required for deployments and scripts that sign transactions
# -----------------------------------------------------------------------------
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# -----------------------------------------------------------------------------
# RPC URLs — foundry.toml; scripts/deploy.js; scripts/verify.js; JS scripts
# -----------------------------------------------------------------------------
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# -----------------------------------------------------------------------------
# Verification — foundry.toml [etherscan] (Basescan API key)
# -----------------------------------------------------------------------------
BASESCAN_API_KEY=your_basescan_api_key_here

# -----------------------------------------------------------------------------
# Referral contracts — Deploy_sepolia.s.sol, Deploy_base.s.sol; scripts/deploy.js;
# scripts/verify.js (ReferralGraph / RewardDistributor constructor args)
# -----------------------------------------------------------------------------
# Server oracle for batchRegister / distributeChainRewards; defaults to deployer if unset
REFERRAL_ORACLE=
# bytes32 group id (0x + 64 hex) — must match server REFERRAL_GROUP_ID
REFERRAL_GROUP_ID=

# -----------------------------------------------------------------------------
# JS scripts — address resolution (mint / deploy helpers)
# -----------------------------------------------------------------------------
# If true, addresses are taken from latest deployment / server contract JSON.
# If false, set PAYMENT_TOKEN_ADDRESS below for manual mode.
USE_LATEST_DEPLOYMENT=true

# scripts/sepolia/mintPaymentToken.js (manual mode when USE_LATEST_DEPLOYMENT=false)
PAYMENT_TOKEN_ADDRESS=

# scripts/sepolia/mintPaymentToken.js — recipient for minted mock USDC
RECIPIENT_ADDRESS=

# scripts/sepolia/mintPaymentToken.js — Mock USDC amount (6 decimals); default 10000000000
AMOUNT=10000000000

# =============================================================================
# Quick reference — which files read which variables
# =============================================================================
#
# foundry.toml
#   BASE_SEPOLIA_RPC_URL, BASE_RPC_URL, BASESCAN_API_KEY
#
# Deploy_sepolia.s.sol, Deploy_base.s.sol
#   PRIVATE_KEY, REFERRAL_ORACLE, REFERRAL_GROUP_ID
#
# scripts/deploy.js
#   PRIVATE_KEY, BASE_SEPOLIA_RPC_URL (sepolia) or BASE_RPC_URL (base), REFERRAL_ORACLE
#
# scripts/verify.js
#   PRIVATE_KEY, BASE_SEPOLIA_RPC_URL (sepolia) or BASE_RPC_URL (base), REFERRAL_ORACLE
#
# scripts/sepolia/mintPaymentToken.js
#   PRIVATE_KEY, BASE_SEPOLIA_RPC_URL, USE_LATEST_DEPLOYMENT, RECIPIENT_ADDRESS, AMOUNT,
#   PAYMENT_TOKEN_ADDRESS
