# =============================================================================
# CONTRACTS / SCRIPTS ENVIRONMENT
# =============================================================================
# Copy to contracts/.env and fill in values.
#
# Consumers:
#   - foundry.toml ([rpc_endpoints], [etherscan])
#   - contracts/script/Deploy.s.sol, Deploy_sepolia.s.sol, Deploy_base.s.sol
#   - scripts/deploy.js, scripts/verify.js
#   - scripts/base/*.js, scripts/sepolia/*.js
#
# All scripts load contracts/.env via dotenv (from repo root).

# -----------------------------------------------------------------------------
# Required for deployments and scripts that sign transactions
# -----------------------------------------------------------------------------
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# -----------------------------------------------------------------------------
# RPC URLs — foundry.toml; scripts/deploy.js; scripts/verify.js; JS scripts
# -----------------------------------------------------------------------------
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# -----------------------------------------------------------------------------
# Verification — foundry.toml [etherscan] (Basescan API key)
# -----------------------------------------------------------------------------
BASESCAN_API_KEY=your_basescan_api_key_here

# -----------------------------------------------------------------------------
# Referral contracts — Deploy_sepolia.s.sol, Deploy_base.s.sol; scripts/deploy.js;
# scripts/verify.js (ReferralGraph / RewardDistributor constructor args)
# -----------------------------------------------------------------------------
REFERRAL_ORACLE=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Deploy.s.sol only — yieldToken DepositManager (custom USDC + Aave V3 pool)
# -----------------------------------------------------------------------------
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
AAVE_V3_POOL_ADDRESS=0xA238Dd80C259a72e81d7e4664a9801593F98d1c5

# -----------------------------------------------------------------------------
# JS scripts — address resolution
# -----------------------------------------------------------------------------
# If true, addresses are taken from latest deployment / server contract JSON.
# If false, set the manual addresses in the next section.
USE_LATEST_DEPLOYMENT=true

# -----------------------------------------------------------------------------
# Manual contract addresses (required when USE_LATEST_DEPLOYMENT=false)
# -----------------------------------------------------------------------------
# scripts/base/* — Base mainnet
DEPOSIT_MANAGER_ADDRESS=
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7c32D4f71b54bdA02913
PLATFORM_TOKEN_ADDRESS=

# scripts/sepolia/* — Base Sepolia
PAYMENT_TOKEN_ADDRESS=

# -----------------------------------------------------------------------------
# scripts/base/depositUSDC.js
# -----------------------------------------------------------------------------
USDC_AMOUNT=1000000

# -----------------------------------------------------------------------------
# scripts/base/emergencyWithdrawAll.js — recipient for withdrawn USDC (optional)
# scripts/sepolia/mintPaymentToken.js — recipient for minted mock USDC (optional)
# -----------------------------------------------------------------------------
RECIPIENT_ADDRESS=

# -----------------------------------------------------------------------------
# scripts/base/checkPlatformTokenBalance.js
# -----------------------------------------------------------------------------
# Optional comma-separated wallets to include in the report (in addition to deployer)
CHECK_ADDRESSES=

# -----------------------------------------------------------------------------
# scripts/sepolia/depositUSDC.js
# -----------------------------------------------------------------------------
# Uses USDC_AMOUNT (same variable as scripts/base/depositUSDC.js)

# -----------------------------------------------------------------------------
# scripts/sepolia/mintPaymentToken.js
# -----------------------------------------------------------------------------
# Mock USDC amount to mint (6 decimals) — default in script: 10000000000
AMOUNT=10000000000

# =============================================================================
# Quick reference — which files read which variables
# =============================================================================
#
# foundry.toml
#   BASE_SEPOLIA_RPC_URL, BASE_RPC_URL, BASESCAN_API_KEY
#
# Deploy.s.sol
#   PRIVATE_KEY, USDC_TOKEN_ADDRESS, AAVE_V3_POOL_ADDRESS
#
# Deploy_sepolia.s.sol, Deploy_base.s.sol
#   PRIVATE_KEY, REFERRAL_ORACLE
#
# scripts/deploy.js
#   PRIVATE_KEY, BASE_SEPOLIA_RPC_URL (sepolia) or BASE_RPC_URL (base), REFERRAL_ORACLE
#
# scripts/verify.js
#   PRIVATE_KEY, BASE_SEPOLIA_RPC_URL (sepolia) or BASE_RPC_URL (base), REFERRAL_ORACLE
#
# scripts/base/depositUSDC.js
#   PRIVATE_KEY, BASE_RPC_URL, USE_LATEST_DEPLOYMENT,
#   DEPOSIT_MANAGER_ADDRESS, USDC_ADDRESS, PLATFORM_TOKEN_ADDRESS, USDC_AMOUNT
#
# scripts/base/emergencyWithdrawAll.js
#   PRIVATE_KEY, BASE_RPC_URL, USE_LATEST_DEPLOYMENT, RECIPIENT_ADDRESS,
#   DEPOSIT_MANAGER_ADDRESS, USDC_ADDRESS, PLATFORM_TOKEN_ADDRESS
#
# scripts/base/checkPlatformTokenBalance.js
#   PRIVATE_KEY, BASE_RPC_URL, USE_LATEST_DEPLOYMENT, CHECK_ADDRESSES,
#   DEPOSIT_MANAGER_ADDRESS, USDC_ADDRESS, PLATFORM_TOKEN_ADDRESS
#
# scripts/sepolia/depositUSDC.js
#   PRIVATE_KEY, BASE_SEPOLIA_RPC_URL, USE_LATEST_DEPLOYMENT, USDC_AMOUNT,
#   DEPOSIT_MANAGER_ADDRESS, PAYMENT_TOKEN_ADDRESS, PLATFORM_TOKEN_ADDRESS
#
# scripts/sepolia/mintPaymentToken.js
#   PRIVATE_KEY, BASE_SEPOLIA_RPC_URL, USE_LATEST_DEPLOYMENT, RECIPIENT_ADDRESS, AMOUNT,
#   PAYMENT_TOKEN_ADDRESS
