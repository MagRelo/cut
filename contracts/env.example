# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# Required for all deployments and scripts
# -----------------------------------------------------------------------------
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# -----------------------------------------------------------------------------
# Network RPC URLs
# -----------------------------------------------------------------------------
# Base Sepolia testnet (for testing)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://sepolia.base.org

# Base mainnet (for production)
BASE_RPC_URL=https://mainnet.base.org

# -----------------------------------------------------------------------------
# yieldToken only — required for Deploy.s.sol (custom USDC + Aave pool)
# -----------------------------------------------------------------------------
# contestCatalyst and referralTree ship no .env.example; they need only PRIVATE_KEY + RPC in this repo.
# DepositManager (lib/yieldToken) third arg is Aave V3 Pool (IPool), not a Compound cToken.
# Base mainnet examples below; use your chain’s USDC + Aave Pool from Aave address books if deploying elsewhere.
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
AAVE_V3_POOL_ADDRESS=0xA238Dd80C259a72e81d7e4664a9801593F98d1c5

# -----------------------------------------------------------------------------
# Referral contracts (Deploy_base / Deploy_sepolia)
# -----------------------------------------------------------------------------
# Optional oracle authorized at deploy; omit or set to zero address for none
REFERRAL_ORACLE=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Contract Verification
# -----------------------------------------------------------------------------
BASESCAN_API_KEY=your_basescan_api_key_here

# -----------------------------------------------------------------------------
# Script Configuration Options
# -----------------------------------------------------------------------------

# USE_LATEST_DEPLOYMENT - If true, scripts will auto-detect contract addresses from latest deployment
# If false, you must provide contract addresses below
# Used by: depositUSDC.js, emergencyWithdrawAll.js, createEscrow.js, mintPaymentToken.js
USE_LATEST_DEPLOYMENT=true

# -----------------------------------------------------------------------------
# Manual Contract Addresses (required when USE_LATEST_DEPLOYMENT=false)
# -----------------------------------------------------------------------------

# For Base mainnet scripts (scripts/base/)
DEPOSIT_MANAGER_ADDRESS=
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7c32D4f71b54bdA02913
PLATFORM_TOKEN_ADDRESS=

# For Sepolia testnet scripts (scripts/sepolia/)
PAYMENT_TOKEN_ADDRESS=
ESCROW_FACTORY_ADDRESS=

# -----------------------------------------------------------------------------
# Base Scripts - depositUSDC.js
# -----------------------------------------------------------------------------
# Amount of USDC to deposit (6 decimals) - Default: 1000000 (1 USDC)
USDC_AMOUNT=1000000

# -----------------------------------------------------------------------------
# Base Scripts - emergencyWithdrawAll.js
# -----------------------------------------------------------------------------
# Address to receive emergency withdrawal funds (defaults to wallet address if not set)
RECIPIENT_ADDRESS=

# -----------------------------------------------------------------------------
# Sepolia Scripts - createEscrow.js
# -----------------------------------------------------------------------------
# Deposit amount for escrow in CUT tokens (18 decimals) - Default: 1000000000000000000 (1 CUT)
DEPOSIT_AMOUNT=1000000000000000000

# End time for escrow (Unix timestamp) - Default: 24 hours from now if not set
END_TIME=

# Oracle address for escrow settlement (required for createEscrow.js)
ORACLE_ADDRESS=

# Oracle fee in basis points (500 = 5%) - Default: 500
ORACLE_FEE=500

# -----------------------------------------------------------------------------
# Sepolia Scripts - mintPaymentToken.js
# -----------------------------------------------------------------------------
# Amount to mint (6 decimals for USDC) - Default: 10000000000 (10,000 USDC)
AMOUNT=10000000000
