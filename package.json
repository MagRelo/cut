{
  "name": "cut",
  "version": "1.0.0",
  "description": "Play The Cut application",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "start": "cd server/dist && node src/index.js",
    "client:dev": "pnpm --filter client run dev",
    "client:build": "pnpm --filter client run build",
    "client:lint": "pnpm --filter client run lint",
    "client:preview": "pnpm --filter client run preview",
    "client:storybook": "pnpm --filter client run storybook",
    "client:build-storybook": "pnpm --filter client run build-storybook",
    "server:dev": "pnpm --filter server run dev",
    "server:build": "pnpm --filter server run build",
    "docker:build": "bash docker/build.sh",
    "db:start": "docker compose -f docker/docker-compose.yml up -d",
    "db:stop": "docker compose -f docker/docker-compose.yml down",
    "db:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:reset": "docker compose -f docker/docker-compose.yml down -v && docker compose -f docker/docker-compose.yml up -d && sleep 5 && pnpm run prisma:migrate && pnpm --filter server run prisma:seed",
    "prisma:generate": "pnpm --filter server run prisma:generate",
    "prisma:migrate": "pnpm --filter server run prisma:migrate",
    "prisma:studio": "pnpm --filter server run prisma:studio",
    "prisma:seed": "pnpm --filter server run prisma:seed",
    "test": "pnpm --filter server run test",
    "test:coverage": "pnpm --filter server run test:coverage",
    "test:ui": "pnpm --filter server run test:ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "concurrently \"pnpm run server:dev\" \"pnpm run client:dev\"",
    "mint-tokens": "node scripts/sepolia/mintPaymentToken.js",
    "deposit-usdc": "node scripts/sepolia/depositUSDC.js",
    "push-primary-payouts": "node scripts/sepolia/pushPayouts.js primary",
    "push-secondary-payouts": "node scripts/sepolia/pushPayouts.js secondary",
    "claim-oracle-fee": "node scripts/sepolia/claimOracleFee.js",
    "sepolia:claim-oracle-fee": "node scripts/sepolia/claimOracleFee.js",
    "base:deposit-usdc": "node scripts/base/depositUSDC.js",
    "deploy": "pnpm --filter @cut/sport-sdk run build && pnpm --filter @cut/sport-pga-golf run build && pnpm --filter @cut/secondary-pricing run build && pnpm run client:build && pnpm run server:build && pnpm run docker:build",
    "release": "pnpm run deploy",
    "deploy:contracts": "node scripts/deploy.js",
    "deploy:contracts:sepolia": "node scripts/deploy.js sepolia",
    "deploy:contracts:base": "node scripts/deploy.js base",
    "sepolia:deploy-contest-factory": "node scripts/sepolia/deployContestFactory.js",
    "sepolia:deploy-referral": "node scripts/sepolia/deployReferral.js",
    "deploy:copy-artifacts": "node scripts/deploy.js copy-artifacts",
    "deploy:full": "pnpm run deploy:contracts && pnpm run deploy",
    "verify:contracts": "node scripts/verify.js",
    "verify:contracts:sepolia": "node scripts/verify.js sepolia",
    "verify:contracts:base": "node scripts/verify.js base",
    "ssh": "ssh deployer@45.55.136.214",
    "swarm:deploy": "ssh root@157.230.6.6 'cd /opt/cut && docker pull magrelo/cut-v4:latest && docker stack deploy --detach=true -c swarm/stack.yml cut'"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "viem": "^2.47.4"
  }
}
