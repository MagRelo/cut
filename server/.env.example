# ===========================================
# Environment Configuration
# ===========================================
# Application environment (development, production, test)
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT secret key for token signing
# Required: Recommended (defaults to "temporary-secret-key" if not set)
JWT_SECRET=your-super-secret-jwt-key-here

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL database connection URL
# Required: Yes
DATABASE_URL=postgresql://playthecut:playthecut@localhost:5432/playthecut

# Hosted production DB — used only by `pnpm run db:pull-prod` (never set as DATABASE_URL)
# PROD_DATABASE_URL=postgresql://user:pass@your-managed-host:25060/defaultdb?sslmode=require

# Legacy prod snapshot for Phase 9 migration (must differ from DATABASE_URL)
# LEGACY_DATABASE_URL=postgresql://user:pass@localhost:5432/playthecut_legacy

# ===========================================
# Blockchain Configuration
# ===========================================
# OPS_ORACLE — single ops oracle key (contest + referral). Signs create / settle /
# push-payouts and referral register/batchRegister. The address is derived from this key.
# Required: Yes
OPS_ORACLE_PK=0x...

# Optional: pin the OPS_ORACLE address explicitly (otherwise derived from OPS_ORACLE_PK)
# OPS_ORACLE_ADDRESS=0x...

# Base mainnet RPC URL (default: https://mainnet.base.org)
# Required: Optional (only needed for Base mainnet interactions)
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia testnet RPC URL (default: https://sepolia.base.org)
# Required: Optional (only needed for Base Sepolia testnet interactions)
# Coinbase CDP: use the full Node URL from portal (Products → Node → Base Sepolia).
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ===========================================
# Feature Flags
# ===========================================
# Enable/disable cron jobs (true/false)
ENABLE_CRON=false

# Better Stack heartbeat URL (cron host only — set in swarm/env/cron.env in production).
# Reports pipeline success, step failures (exit code 1 + output), and fatal process crashes.
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/your-token

# Side bets (DataGolf finish markets + lineup parlays). When off, /api/bets/side/* returns 403.
# truthy: true, True, 1, yes (see `sideBetsEnabled()`). Root `server/.env` overrides `.env.development`.
SIDE_BETS_ENABLED=false
# DataGolf API key (Scratch Plus). Required for side-bet quote ingest when enabled, and for
# Data Golf rankings during tournament init (`preds/get-dg-rankings`).
# DATAGOLF_API_KEY=
# DataGolf tour for `field-updates` + outrights, and for **tournament init** PGA id → dg_id when attaching DG rankings (`pga` default, `opp` opposite field).
# SIDE_BET_DATAGOLF_TOUR=pga
# Fractional house margin on P(at least k) pricing (0 = fair; 0.08 = 8% shorter odds). Default 0 if unset.
SIDE_BET_PRICING_MARGIN=0.08

# Enable/disable token minting (true/false)
ENABLE_TOKEN_MINTING=false

# ===========================================
# PGA Tour API
# ===========================================
# PGA Tour API key for all PGA Tour data (schedule, field, player data, etc.)
# Required: Optional (defaults to "da2-gsrx5bibzbb4njvhl7t37wqyl4")
PGA_API_KEY=da2-gsrx5bibzbb4njvhl7t37wqyl4

# ===========================================
# F1 data (OpenF1 + Jolpica)
# ===========================================
# Bearer token for OpenF1 live session window (optional for historical replay)
# OPENF1_API_TOKEN=
# Jolpica/Ergast base URL override (default: https://api.jolpi.ca/ergast/f1)
# JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

# ===========================================
# Commodities (Hyperliquid HIP-3 perps)
# ===========================================
# COMMODITIES_SESSION_TZ=America/New_York
# COMMODITIES_SESSION_OPEN=09:30
# COMMODITIES_SESSION_CLOSE=16:00
# HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# COMMODITIES_USE_FIXTURE_PRICES=true
# COMMODITIES_HL_CATALOG_TTL_MS=3600000
# COMMODITIES_HL_MARK_CACHE_MS=45000
# COMMODITIES_MIN_DAY_VOLUME=100000
# COMMODITIES_MIN_OPEN_INTEREST=100

# ===========================================
# Email Configuration (MailerSend)
# ===========================================
# Required for product emails and script:send-test-email / POST /api/admin/test-email
MAILERSEND_API_KEY=your-mailersend-api-key

# Verified sending address on your MailerSend domain
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com

# Display name (default: Play The Cut)
MAILERSEND_FROM_NAME=Play The Cut

# Public app URL for email images (default: https://playthecut.com). Logo: /logo-transparent.png
# APP_PUBLIC_URL=https://playthecut.com

# ===========================================
# SMS Configuration (Twilio)
# ===========================================
# Twilio account SID
# Required: Optional if not using SMS features
TWILIO_ACCOUNT_SID=your-twilio-account-sid

# Twilio auth token
# Required: Optional if not using SMS features
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Twilio phone number (E.164 format: +1234567890)
# Required: Optional if not using SMS features
TWILIO_PHONE_NUMBER=+1234567890
# Privy (server verifies access tokens)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# PostHog (server-side product analytics; optional)
# Use the same project as the client; distinctId is Cut `user.id` (see posthog.identify on the client).
# POSTHOG_API_KEY=
# Optional if not using the default PostHog US host (match VITE / client `api_host` for self-hosted)
# POSTHOG_HOST=

# Referrals (ReferralGraph contract + optional strict signup)
# REFERRAL_REQUIRED_FOR_SIGNUP=true → new users must send X-Cut-Referrer-Address
REFERRAL_REQUIRED_FOR_SIGNUP=false
# 32-byte group id as hex (0x + 64 hex chars); required for Option B graph registration
REFERRAL_GROUP_ID=
# Chain for referral bootstrap/sync scripts (default 84532)
# REFERRAL_SYNC_CHAIN_ID=84532
# ReferralGraph addresses: server/src/contracts/{base,sepolia}.json and client/src/utils/contracts/*
# Referral txs are signed by OPS_ORACLE_PK; the tree root under REFERRAL_ROOT is the OPS_ORACLE address.

