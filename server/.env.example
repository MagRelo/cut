# ===========================================
# Server environment — full catalog
# ===========================================
# Local: copy to server/.env (or .env.development). Root server/.env overrides env-specific files.
# Prod: copy relevant keys into swarm/env/web.env and swarm/env/cron.env (see those examples).
#
# Convention: uncommented = required at startup (or no safe default for this role).
# Commented lines document vars that have code defaults or are optional features.

# --- Startup required (web) ---

# PostgreSQL connection URL
DATABASE_URL=postgresql://playthecut:playthecut@localhost:5432/playthecut

# OPS_ORACLE — contest + referral signing key (0x + 64 hex). Address derived unless OPS_ORACLE_ADDRESS set.
OPS_ORACLE_PK=0x...

# Privy (server verifies access tokens). Required by web startup.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Process / HTTP (defaults — comment out to use defaults) ---

# Application environment (development | production | test). Default when logged: development
# NODE_ENV=development

# Server port. Default: 3000
# PORT=3000

# Comma-separated CORS origins. Default: http://localhost:5173,http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Enable in-process cron on the web server (usually false; use dedicated cron-app host). Default: false
# ENABLE_CRON=false

# Absolute public site origin for OG/meta when not inferable from the request. Default: request origin
# PUBLIC_WEB_URL=https://playthecut.com

# Injected by Docker build (`GIT_SHA` build-arg). Default in /health: unknown
# GIT_SHA=

# --- Blockchain / RPC ---

# Pin OPS_ORACLE address explicitly (otherwise derived from OPS_ORACLE_PK)
# OPS_ORACLE_ADDRESS=0x...

# Base mainnet RPC. Default: https://mainnet.base.org
# BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia RPC. Default: https://sepolia.base.org
# Coinbase CDP: full Node URL from portal (Products → Node → Base Sepolia).
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Feature flags ---

# Side bets API gate. truthy: true | 1 | yes. Default: off
# SIDE_BETS_ENABLED=false

# Fractional house margin on side-bet P(at least k) pricing. Default: 0
# SIDE_BET_PRICING_MARGIN=0

# DataGolf tour for field-updates / outrights / rankings attach. Default: pga (use opp for opposite field)
# SIDE_BET_DATAGOLF_TOUR=pga

# Mint test tokens on user provision. Default: false
# ENABLE_TOKEN_MINTING=false

# DataGolf API key (Scratch Plus). Required when side bets / DG rankings are used.
# DATAGOLF_API_KEY=

# --- PGA Tour ---

# Override PGA Tour API key. Some modules fall back to a built-in key if unset; prefer setting explicitly in prod.
# PGA_API_KEY=

# Live-score icon thresholds (percentiles). Unset → sport-package defaults.
# ICON_FLAME_PERCENTILE=
# ICON_SNOW_PERCENTILE=

# --- F1 (OpenF1 + Jolpica) ---

# Bearer token for OpenF1 live session window (optional for historical replay)
# OPENF1_API_TOKEN=

# Jolpica/Ergast base URL. Default: https://api.jolpi.ca/ergast/f1
# JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

# --- Commodities (Hyperliquid HIP-3) ---

# COMMODITIES_SESSION_TZ=America/New_York
# COMMODITIES_SESSION_OPEN=09:30
# COMMODITIES_SESSION_CLOSE=16:30
# HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# COMMODITIES_USE_FIXTURE_PRICES=false
# COMMODITIES_HL_CATALOG_TTL_MS=3600000
# COMMODITIES_HL_MARK_CACHE_MS=45000
# COMMODITIES_MIN_DAY_VOLUME=100000
# COMMODITIES_MIN_OPEN_INTEREST=100

# --- Contest settlement / payouts ---

# Max entries per primary push tx. Default: 40
# CONTEST_PRIMARY_PUSH_CHUNK=40

# Max entries per secondary push tx. Default: 50
# CONTEST_SECONDARY_PUSH_CHUNK=50

# --- Referrals (ReferralGraph) ---

# New users must send X-Cut-Referrer-Address. Default: false
# REFERRAL_REQUIRED_FOR_SIGNUP=false

# 32-byte group id (0x + 64 hex). Required for Option B graph registration / contest create.
REFERRAL_GROUP_ID=

# Chain for referral bootstrap/sync scripts. Default: 84532 (Base Sepolia)
# REFERRAL_SYNC_CHAIN_ID=84532
# ReferralGraph addresses: server/src/contracts/{base,sepolia}.json (and client utils/contracts/*)
# Referral txs are signed by OPS_ORACLE_PK; tree root under REFERRAL_ROOT is the OPS_ORACLE address.

# --- Email (MailerSend) ---

# Required for product emails and script:send-test-email / POST /api/admin/test-email
# MAILERSEND_API_KEY=
# MAILERSEND_FROM_EMAIL=noreply@yourdomain.com

# Display name. Default: Play The Cut
# MAILERSEND_FROM_NAME=Play The Cut

# Public app URL for email assets/links. Default: https://playthecut.com
# Alias: PUBLIC_APP_URL
# APP_PUBLIC_URL=https://playthecut.com
# PUBLIC_APP_URL=https://playthecut.com

# Override behind-the-scenes email HTML body (optional)
# BTS_EMAIL_BODY_HTML=

# Unsubscribe token HMAC secret. Falls back to MAILERSEND_API_KEY, then throws if both unset.
# (Not a general JWT auth secret; not defaulted to "temporary-secret-key".)
# JWT_SECRET=

# --- SMS (Twilio) — optional ---

# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1234567890

# --- Analytics / observability ---

# Server-side PostHog (optional; same project as client). Unset = no-op.
# POSTHOG_API_KEY=
# POSTHOG_HOST=

# Better Stack heartbeat (cron host). Unset = heartbeats skipped.
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/your-token

# --- Scripts / ops only (never use as prod DATABASE_URL) ---

# Hosted production DB — used only by `pnpm run db:pull-prod`
# PROD_DATABASE_URL=postgresql://user:pass@your-managed-host:25060/defaultdb?sslmode=require

# Legacy prod snapshot for migrate-from-legacy (must differ from DATABASE_URL)
# LEGACY_DATABASE_URL=postgresql://user:pass@localhost:5432/playthecut_legacy

# script:push-contest-payouts — contest id if not passed as CLI arg
# CONTEST_ID=

# script:send-blast — event / tournament id
# EVENT_ID=
# TOURNAMENT_ID=

# script:send-test-email — recipient
# TO=

# script:email-preview — open browser when 1/true
# OPEN=

# script:sync-user-wallets-from-privy
# LIMIT=
# PREFERRED_CHAIN_ID=
