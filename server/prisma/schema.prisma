generator client {
  provider = "prisma-client-js"
  seed     = "tsx prisma/seed.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & social (sport-agnostic)
// ---------------------------------------------------------------------------

model User {
  id                        String    @id @default(cuid())
  privyUserId               String?   @unique
  email                     String?   @unique
  phone                     String?   @unique
  password                  String?
  name                      String
  userType                  String    @default("USER")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  settings                  Json?
  isVerified                Boolean   @default(false)
  lastLoginAt               DateTime?
  loginAttempts             Int       @default(0)
  lockedUntil               DateTime?
  verificationCode          String?
  verificationCodeExpiresAt DateTime?

  referrerAddress       String?
  referralGroupId       String?
  referredByUserId      String?
  referralChainId       Int?
  referralRecordedAt    DateTime?
  referralOnchainTxHash String?

  userGroups                   UserGroupMember[]
  lineups                      Lineup[]
  contestLineups               ContestLineup[]
  onchainPayments              OnchainPayment[]
  contestSecondaryParticipants ContestSecondaryParticipant[]
  wallets                      UserWallet[]
  sideBetTickets               SideBetTicket[]
  emailSendLogs                EmailSendLog[]
  referredBy                   User?                         @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers                User[]                        @relation("UserReferrals")

  @@index([email])
  @@index([phone])
  @@index([verificationCode])
  @@index([referredByUserId])
  @@index([referrerAddress])
  @@index([referredByUserId, referralChainId, referralGroupId])
}

model UserWallet {
  id        String   @id @default(cuid())
  userId    String
  chainId   Int
  publicKey String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([chainId, publicKey])
  @@index([userId])
  @@index([chainId])
  @@index([publicKey])
}

model UserGroup {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  inviteCode            String?  @unique
  inviteReferrerAddress String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  members  UserGroupMember[]
  contests Contest[]

  @@index([name])
}

model UserGroupMember {
  id          String   @id @default(cuid())
  userId      String
  userGroupId String
  role        String   @default("MEMBER")
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  userGroup UserGroup @relation(fields: [userGroupId], references: [id])

  @@unique([userId, userGroupId])
}

// ---------------------------------------------------------------------------
// Sport registry & competition events
// ---------------------------------------------------------------------------

model Sport {
  id           String  @id
  name         String
  slug         String  @unique
  isEnabled    Boolean @default(true)
  rosterRules  Json
  scoringRules Json

  events       CompetitionEvent[]
  participants Participant[]
}

model CompetitionEvent {
  id         String   @id @default(cuid())
  sportId    String
  externalId String
  isActive   Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sport          Sport              @relation(fields: [sportId], references: [id])
  participants   EventParticipant[]
  lineups        Lineup[]
  contests       Contest[]
  sideBetMarkets SideBetMarket[]
  emailSendLogs  EmailSendLog[]

  @@unique([sportId, externalId])
  @@index([sportId, isActive])
  @@index([sportId, externalId])
}

model Participant {
  id          String   @id @default(cuid())
  sportId     String
  externalId  String?
  displayName String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sport             Sport              @relation(fields: [sportId], references: [id])
  eventParticipants EventParticipant[]

  @@unique([sportId, externalId])
  @@index([sportId])
}

model EventParticipant {
  id            String   @id @default(cuid())
  eventId       String
  participantId String
  scoreData     Json?
  total         Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event       CompetitionEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  lineupPicks LineupPick[]

  @@unique([eventId, participantId])
  @@index([eventId])
  @@index([participantId])
}

// ---------------------------------------------------------------------------
// Lineups & contest entries
// ---------------------------------------------------------------------------

model Lineup {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  contestId  String?
  name       String
  prediction Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  event          CompetitionEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contest        Contest?        @relation(fields: [contestId], references: [id])
  picks          LineupPick[]
  contestLineups ContestLineup[]
  sideBetMarket  SideBetMarket?

  @@index([userId, eventId])
  @@index([userId, eventId, contestId])
}

model LineupPick {
  id                 String   @id @default(cuid())
  lineupId           String
  eventParticipantId String
  slotIndex          Int?
  createdAt          DateTime @default(now())

  lineup           Lineup           @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  eventParticipant EventParticipant @relation(fields: [eventParticipantId], references: [id], onDelete: Cascade)

  @@unique([lineupId, eventParticipantId])
  @@index([lineupId])
}

model Contest {
  id          String   @id @default(cuid())
  name        String
  endTime     DateTime
  address     String
  chainId     Int
  eventId     String
  status      String
  userGroupId String?
  description String?
  settings    Json?
  results     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event                 CompetitionEvent              @relation(fields: [eventId], references: [id])
  userGroup             UserGroup?                      @relation(fields: [userGroupId], references: [id])
  contestLineups        ContestLineup[]
  lineups               Lineup[]
  secondaryParticipants ContestSecondaryParticipant[]
  onchainPayments       OnchainPayment[]
  timelines             ContestLineupTimeline[]

  @@index([eventId])
  @@index([userGroupId])
  @@index([status])
  @@index([chainId])
  @@index([chainId, eventId])
}

model ContestLineup {
  id        String   @id @default(cuid())
  contestId String
  lineupId  String
  userId    String
  entryId   String?
  status    String
  score     Int?
  position  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contest   Contest                 @relation(fields: [contestId], references: [id])
  lineup    Lineup                  @relation(fields: [lineupId], references: [id])
  user      User                    @relation(fields: [userId], references: [id])
  timelines ContestLineupTimeline[]

  @@unique([contestId, lineupId])
  @@unique([contestId, entryId])
  @@index([contestId])
  @@index([userId])
  @@index([status])
}

model ContestLineupTimeline {
  id              String   @id @default(cuid())
  contestLineupId String
  contestId       String
  timestamp       DateTime
  roundNumber     Int
  score           Int
  position        Int
  sharePrice      Float?
  createdAt       DateTime @default(now())

  contestLineup ContestLineup @relation(fields: [contestLineupId], references: [id])
  contest       Contest       @relation(fields: [contestId], references: [id])

  @@index([contestId, timestamp])
  @@index([contestLineupId, timestamp])
}

// ---------------------------------------------------------------------------
// On-chain payments & secondary market
// ---------------------------------------------------------------------------

enum PaymentKind {
  PRIMARY
  SECONDARY
  REFERRAL
}

model OnchainPayment {
  id              String      @id @default(cuid())
  kind            PaymentKind
  walletAddress   String
  userId          String?
  contestId       String?
  chainId         Int
  tokenAddress    String
  amountWei       String
  transactionHash String
  logIndex        Int?
  metadata        Json?
  notifiedAt      DateTime?
  createdAt       DateTime    @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  contest Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@unique([transactionHash, logIndex, walletAddress])
  @@index([userId])
  @@index([contestId])
  @@index([transactionHash])
  @@index([kind])
  @@index([notifiedAt])
}

model ContestSecondaryParticipant {
  id                  String   @id @default(cuid())
  contestId           String
  entryId             String
  walletAddress       String
  userId              String?
  chainId             Int
  lastTransactionHash String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([contestId, entryId, walletAddress])
  @@index([contestId, entryId])
  @@index([walletAddress])
}

// ---------------------------------------------------------------------------
// Side bets (prop bets — optional per sport)
// ---------------------------------------------------------------------------

enum SideBetMarketStatus {
  UNAVAILABLE
  OPEN
  LOCKED
  SETTLING
  SETTLED
  VOID
  CLOSED
}

enum SideBetTicketStatus {
  OPEN
  WON
  LOST
  VOID
  REFUND_PENDING
}

model SideBetMarket {
  id                 String              @id @default(cuid())
  lineupId           String              @unique
  eventId            String
  status             SideBetMarketStatus @default(UNAVAILABLE)
  unavailableReason  String?
  quoteVersion       Int                 @default(0)
  dgEventId          Int?
  dgEventName        String?
  dgFieldLastUpdated String?
  dgOddsLastUpdated  String?
  datagolfTour       String              @default("pga")
  lockedAt           DateTime?
  settledAt          DateTime?
  closedAt           DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  lineup     Lineup            @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  event      CompetitionEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  selections SideBetSelection[]
  tickets    SideBetTicket[]

  @@index([eventId])
  @@index([status])
}

model SideBetSelection {
  id              String @id @default(cuid())
  sideBetMarketId String
  hitsRequired    Int
  topN            Int
  decimalOdds     Float
  americanDisplay String
  quoteVersion    Int

  sideBetMarket SideBetMarket @relation(fields: [sideBetMarketId], references: [id], onDelete: Cascade)

  @@unique([sideBetMarketId, hitsRequired, topN, quoteVersion])
  @@index([sideBetMarketId, quoteVersion])
}

model SideBetTicket {
  id                         String              @id @default(cuid())
  sideBetMarketId            String
  userId                     String
  hitsRequired               Int
  topN                       Int
  stakeAmount                Float
  decimalOddsAtPlacement     Float
  americanDisplayAtPlacement String
  quoteVersionAtPlacement    Int
  /// Four `EventParticipant.id` values for this event (sorted); set at placement for settlement.
  eventParticipantIds        String[]            @default([])
  status                     SideBetTicketStatus @default(OPEN)
  fundingTxHash              String?
  settlementNotes            Json?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  sideBetMarket SideBetMarket @relation(fields: [sideBetMarketId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fundingTxHash])
  @@index([userId])
  @@index([sideBetMarketId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Email program
// ---------------------------------------------------------------------------

model EmailSendLog {
  id             String   @id @default(cuid())
  kind           String
  dedupeKey      String   @unique
  recipientEmail String
  userId         String?
  eventId        String?
  campaignId     String?
  sentAt         DateTime @default(now())

  user  User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  event CompetitionEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([kind])
  @@index([userId])
  @@index([eventId])
  @@index([campaignId])
}
