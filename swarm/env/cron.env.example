# ===========================================
# Swarm cron.env — dedicated cron-app host
# ===========================================
# Not used by Docker Swarm in this repo (no cron service in stack).
# Copy to cron.env on the host that runs `node dist/src/cron-app.js` (e.g. Pi): chmod 600.
# Full catalog: server/.env.example
#
# Uncommented = required by cron-app.ts startup.
# Commented = defaults / pipeline features (PGA, settle, referral sync, etc.).
# Web-only vars (PORT, ALLOWED_ORIGINS, Privy, JWT, MailerSend, Twilio, PostHog, PUBLIC_WEB_URL)
# are omitted — cron-app does not serve the product HTTP API.

# --- Required ---

NODE_ENV=production
ENABLE_CRON=true

DATABASE_URL=postgresql://user:pass@your-managed-host:25060/defaultdb?sslmode=require

# Prisma pool / timeouts (appended to DATABASE_URL). Prefer direct DB URL, not pgBouncer.
# Socket timeout must tolerate Pi → managed Postgres RTT; default in code is 60.
PRISMA_SOCKET_TIMEOUT=60
# PRISMA_CONNECTION_LIMIT=5
# PRISMA_POOL_TIMEOUT=20
# PRISMA_CONNECT_TIMEOUT=10

# OPS_ORACLE — contest + referral; address derived from key unless OPS_ORACLE_ADDRESS set
OPS_ORACLE_PK=

# --- Optional / defaults (commented) ---

# Live PGA contest commentary (optional).
# CONTEST_COMMENTARY_ENABLED=false
# CURSOR_API_KEY=

# Better Stack heartbeat — success GET; failure POST {URL}/{exitCode} with body.
# Create a Heartbeat monitor; grace period 10–15 min recommended. Unset = skipped.
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/your-token

# OPS_ORACLE_ADDRESS=0x...

# BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Must match on-chain ReferralGraph / web REFERRAL_GROUP_ID for sync + settle referral fees
# REFERRAL_GROUP_ID=
# REFERRAL_SYNC_CHAIN_ID=84532

# SIDE_BETS_ENABLED=false
# SIDE_BET_PRICING_MARGIN=0
# SIDE_BET_DATAGOLF_TOUR=pga
# DATAGOLF_API_KEY=

# PGA_API_KEY=
# ICON_FLAME_PERCENTILE=
# ICON_SNOW_PERCENTILE=

# OPENF1_API_TOKEN=
# JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

# COMMODITIES_SESSION_TZ=America/New_York
# COMMODITIES_SESSION_OPEN=09:30
# COMMODITIES_SESSION_CLOSE=16:30
# HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# COMMODITIES_USE_FIXTURE_PRICES=false
# COMMODITIES_HL_CATALOG_TTL_MS=3600000
# COMMODITIES_HL_MARK_CACHE_MS=45000
# COMMODITIES_MIN_DAY_VOLUME=100000
# COMMODITIES_MIN_OPEN_INTEREST=100

# CONTEST_PRIMARY_PUSH_CHUNK=40
# CONTEST_SECONDARY_PUSH_CHUNK=50

# Injected by image/build if you copy the same release artifact
# GIT_SHA=
