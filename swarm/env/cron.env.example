# Not used by Docker Swarm in this repo (no cron service in stack). Copy to cron.env on
# whatever host runs `cron-app` (e.g. Raspberry Pi): chmod 600 cron.env
# Typically mirrors web.env for DATABASE_URL, oracle keys, PGA, RPC, etc.

NODE_ENV=production
ENABLE_CRON=true

DATABASE_URL=postgresql://user:pass@your-managed-host:25060/defaultdb?sslmode=require

ORACLE_ADDRESS=0x
ORACLE_PRIVATE_KEY=

# Better Stack heartbeat — reports success, step failures, and fatal process errors.
# Success: GET the URL. Failure: POST {URL}/{exitCode} with error output in the body.
# Create a Heartbeat monitor in Better Stack; grace period 10–15 min recommended.
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/your-token

# Privy and JWT are not required by cron-app.ts validation, but harmless if present.
# PRIVY_APP_ID=
# PRIVY_APP_SECRET=
