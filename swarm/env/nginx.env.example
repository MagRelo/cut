# Copy to nginx.env on the manager (chmod 600). Used by scripts and optional tooling.
# The nginx image does not need these as process env unless you extend the image;
# bootstrap-tls.sh / renew-certs.sh source this file for values.

# Primary hostname (A/AAAA records point to this droplet)
PRIMARY_HOSTNAME=your-domain.com

# Let's Encrypt registration email
LETSENCRYPT_EMAIL=you@example.com

# Stack name (must match `docker stack deploy` name; used by scripts for volume names)
STACK_NAME=cut
