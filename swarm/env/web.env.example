# ===========================================
# Swarm web.env — web replicas (2x)
# ===========================================
# Copy to swarm/env/web.env on the manager (chmod 600).
# Client VITE_* are NOT set here — bake via client/.env.production before `pnpm run deploy`.
# Full local/dev catalog: server/.env.example
#
# Uncommented = required for web startup / typical prod.
# Commented = code defaults or optional features.

# --- Required ---

NODE_ENV=production
ENABLE_CRON=false

# Must include your public https origin(s)
ALLOWED_ORIGINS=https://your-domain.com

DATABASE_URL=postgresql://user:pass@your-managed-host:25060/defaultdb?sslmode=require

PRIVY_APP_ID=
PRIVY_APP_SECRET=

# OPS_ORACLE — contest + referral; address derived from key unless OPS_ORACLE_ADDRESS set
OPS_ORACLE_PK=

# Unsubscribe HMAC (falls back to MAILERSEND_API_KEY if unset, then throws when sending)
JWT_SECRET=

# Must match client VITE_REFERRAL_GROUP_ID and on-chain ReferralGraph auth
REFERRAL_GROUP_ID=

# --- Optional / defaults (commented) ---

# PORT=3000

# Absolute public origin for OG/meta. Default: request origin
# PUBLIC_WEB_URL=https://your-domain.com

# Injected by image build; optional override
# GIT_SHA=

# OPS_ORACLE_ADDRESS=0x...

# BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Sepolia soak: keep referral sync on Base Sepolia until Base flip
# REFERRAL_SYNC_CHAIN_ID=84532
# REFERRAL_REQUIRED_FOR_SIGNUP=false

# SIDE_BETS_ENABLED=false
# SIDE_BET_PRICING_MARGIN=0
# SIDE_BET_DATAGOLF_TOUR=pga
# DATAGOLF_API_KEY=

# ENABLE_TOKEN_MINTING=false

# PGA_API_KEY=
# ICON_FLAME_PERCENTILE=
# ICON_SNOW_PERCENTILE=

# OPENF1_API_TOKEN=
# JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1

# COMMODITIES_SESSION_TZ=America/New_York
# COMMODITIES_SESSION_OPEN=09:30
# COMMODITIES_SESSION_CLOSE=16:30
# HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# COMMODITIES_USE_FIXTURE_PRICES=false
# COMMODITIES_HL_CATALOG_TTL_MS=3600000
# COMMODITIES_HL_MARK_CACHE_MS=45000
# COMMODITIES_MIN_DAY_VOLUME=100000
# COMMODITIES_MIN_OPEN_INTEREST=100

# CONTEST_PRIMARY_PUSH_CHUNK=40
# CONTEST_SECONDARY_PUSH_CHUNK=50

# MAILERSEND_API_KEY=
# MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
# MAILERSEND_FROM_NAME=Play The Cut
# APP_PUBLIC_URL=https://your-domain.com
# PUBLIC_APP_URL=https://your-domain.com
# BTS_EMAIL_BODY_HTML=

# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1234567890

# POSTHOG_API_KEY=
# POSTHOG_HOST=
