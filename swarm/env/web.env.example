# Copy to web.env on the manager (chmod 600). Used by Swarm service "web" (2 replicas).
# See server/.env.example for full variable documentation.

NODE_ENV=production
PORT=3000
ENABLE_CRON=false

# Must include your public https origin(s)
ALLOWED_ORIGINS=https://your-domain.com

DATABASE_URL=postgresql://user:pass@your-managed-host:25060/defaultdb?sslmode=require

PRIVY_APP_ID=
PRIVY_APP_SECRET=

ORACLE_ADDRESS=0x
ORACLE_PRIVATE_KEY=

JWT_SECRET=

# Optional: PGA, mail, Twilio, RPC URLs, referrals — same as server/.env.example
